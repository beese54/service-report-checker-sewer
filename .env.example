# WRN Service Report Checker — Environment Variables
# Copy this file to .env and edit as needed.

# ── Web app ───────────────────────────────────────────────────────────────────
# Port the app listens on.
PORT=5000

# Password for the login page.
APP_PASSWORD=wrnchecker

# Maximum upload size in megabytes.
MAX_UPLOAD_MB=200

# ── Storage paths ─────────────────────────────────────────────────────────────
# Where pipeline output JSON/XLSX/contact-sheets are written.
OUTPUT_DIR=/app/pipeline_output

# Path to original (unprocessed) source images (for /originals static mount).
# ORIGINAL_IMAGES_DIR=/data/original_images

# Path to difference-analysis outputs (for /analysis static mount).
# ANALYSIS_DIR=/data/analysis

# Path to the no-obstruction working folder.
# NO_OBSTRUCTION_DIR=/data/no_obstruction

# Path to the ground-truth labels file (must be writable).
# GROUND_TRUTH_PATH=/app/verification/ground_truth.json

# ── ML model ─────────────────────────────────────────────────────────────────
# Absolute path to the YOLOv8 manhole detector weights inside the container.
DETECTOR_MODEL=/app/manhole_detector/v1_positive_only3/weights/best.pt

# ── Stage 2N — SIFT alignment (D1/D4 + U1/U4) ────────────────────────────────
STAGE2N_MIN_INLIERS=10
STAGE2N_MIN_COVERAGE_PCT=25.0

# ── Stage 3N — Washing confidence (D2/D5 + U2/U5) ────────────────────────────
STAGE3N_HIGH_CONFIDENCE=0.50
STAGE3N_MEDIUM_CONFIDENCE=0.30
STAGE3N_PASS_TIER=HIGH

# ── Stage 4N — Geometry (D3/D6 + U3/U6) ──────────────────────────────────────
STAGE4N_REVIEW_IS_ACCEPTED=false

# ── Detector (YOLOv8 manhole gate) ────────────────────────────────────────────
DETECTOR_CONF_ACCEPT=0.70
DETECTOR_CONF_REVIEW=0.30
